{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://damovies.watch/showtime.schema.json",
  "title": "Da Movies Showtime Schedule",
  "type": "object",
  "required": ["event", "assets", "schedule"],
  "additionalProperties": false,
  "properties": {
    "event": {
      "type": "object",
      "required": ["slug", "title", "date", "timezone", "channel", "defaultHoldAsset"],
      "additionalProperties": true,
      "properties": {
        "slug": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "timezone": { "type": "string", "minLength": 1 },
        "channel": { "type": "string", "minLength": 1 },
        "defaultHoldAsset": { "type": "string", "minLength": 1 },
        "ticker": { "type": "array", "items": { "type": "string" } }
      }
    },
    "assets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["title", "playbackId", "assetId", "kind"],
        "additionalProperties": true,
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "playbackId": { "type": "string", "minLength": 1 },
          "assetId": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["vod", "live"] },
          "rating": { "type": "string" },
          "runtime": { "type": "string" },
          "still": { "type": "string" },
          "captions": { "type": "string" },
          "blurb": { "type": "string" },
          "accent": { "type": "string" }
        }
      }
    },
    "schedule": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "start", "end", "asset"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "start": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" },
          "end": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" },
          "asset": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "blurb": { "type": "string" },
          "accent": { "type": "string" }
        }
      }
    }
  }
}
